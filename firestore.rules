/*
  FUAHSE Student Hub - Security Rules
  Eight Pillars Implementation:
  1. Master Gate: Relational Sync (N/A - simple flat structure for now)
  2. Validation Blueprints: isValidUser, isValidCourse, isValidPurchase
  3. Path Variable Hardening
  4. Tiered Identity Logic
  5. Total Array Guarding
  6. PII Isolation (Admin only or Owner only)
  7. Atomicity Guarantee (N/A - simple writes)
  8. Secure List Queries
*/

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Public health check path
    match /test/connection {
      allow read: if true;
    }

    // Common Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Admin Helper
    function isAdmin() { 
      return isSignedIn() && 
             request.auth.token.email.matches('(?i)ben868328@gmail\\.com'); 
    }

    // User Profile Rules
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.isPremium is bool &&
             data.role in ['student', 'admin'] &&
             data.enrolledCourses is list;
             // Temporarily removing createdAt check to fix initialization issues
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /users {
      allow list: if isAdmin();
    }

    // Course Rules (Public for reading, Admin for writing)
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /exams/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /quizzes/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Purchase Rules (Owner can list/get their own)
    function isValidPurchase(data) {
      return data.userId == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.type in ['single', 'all'] &&
             data.timestamp == request.time;
    }

    match /purchases/{purchaseId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidPurchase(incoming());
    }
  }
}
